rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin check: user must have an admin document in adminUsers collection
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isParticipant(chatId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isGroupAdmin(chatId) {
      return isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.groupMetadata.adminId;
    }

    // ----- Validation functions for create operations -----

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName'])
        && data.uid is string
        && data.displayName is string
        && data.displayName.size() > 0;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['participants', 'type', 'updatedAt'])
        && data.participants is list
        && data.participants.size() >= 2
        && data.type in ['private', 'group'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'type', 'timestamp'])
        && data.senderId is string
        && data.type in ['text', 'image', 'video', 'audio', 'call'];
    }

    function isValidCall(data) {
      return data.keys().hasAll(['participants', 'chatId', 'callerId', 'type', 'status', 'createdAt'])
        && data.participants is list
        && data.participants.size() >= 1
        && data.type in ['private', 'group']
        && data.status in ['calling', 'ongoing', 'ended'];
    }

    function isValidSignal(data) {
      return data.keys().hasAll(['from', 'to', 'type', 'data', 'createdAt'])
        && data.from is string
        && data.to is string
        && data.type in ['offer', 'answer', 'candidate'];
    }

    // Admin-only: full access
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Chats
    match /chats/{chatId} {
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants || resource.data.type == 'group' || isAdmin());
      allow create: if isSignedIn() && isValidChat(request.resource.data);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());

      match /messages/{messageId} {
        allow list, get: if isParticipant(chatId) || isAdmin();
        allow create: if (isParticipant(chatId) || isAdmin()) && isValidMessage(request.resource.data);
        allow delete: if isAdmin();
        allow update: if (isParticipant(chatId) || isAdmin()) && (
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && request.resource.data.status in ['delivered', 'read']) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedBy']))
        );
      }
    }

    // Calls
    match /calls/{callId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && isValidCall(request.resource.data);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());

      match /signals/{signalId} {
        allow list, get: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants || isAdmin());
        allow create: if isSignedIn() && isValidSignal(request.resource.data);
        allow delete: if isSignedIn() && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid || isAdmin());
      }

      match /audio/{audioId} {
        allow list, get: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants || isAdmin());
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants || isAdmin());
      }
    }

    // Admin users (managed client-side with password hash verification)
    match /adminUsers/{uid} {
      allow read, create: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isSignedIn() && request.auth.uid == uid;
    }

    // Admin config (password hash - any authenticated user can read, any can create for first setup)
    match /config/{doc} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Admin messages (only admins can send/read)
    match /adminMessages/{docId} {
      allow read, write: if isAdmin();
    }

    // Admin settings (only admins can send/read)
    match /adminSettings/{docId} {
      allow read, write: if isAdmin();
    }

    // Broadcast messages (any authenticated user can create/read)
    match /broadcastMessages/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // Friend requests
    match /friendRequests/{docId} {
      allow read: if isSignedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // Admin delete requests
    match /adminDeleteRequests/{docId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.requestedBy == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin();
    }

    // Group join requests
    match /groupJoinRequests/{docId} {
      allow read: if isSignedIn() && (resource.data.from == request.auth.uid || isGroupAdmin(resource.data.chatId) || isAdmin());
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
      allow update: if isSignedIn() && (isGroupAdmin(resource.data.chatId) || isAdmin());
    }
  }
}
